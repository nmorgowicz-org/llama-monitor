{
  "name": "llama-monitor-ui-tests",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ssh": "playwright test remote-agent-ssh.integration.spec.js",
    "test:ai": "LLAMA_MONITOR_HAS_AI=1 playwright test",
    "test:headed": "playwright test --headless=false",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "capture:list": "node capture.mjs --list-scenarios",
    "capture:sparkline": "node capture.mjs --scenario sparkline",
    "capture:gifs": "node capture.mjs --scenario gifs",
    "update-baseline": "node -e \"import('./update-baseline.mjs').then(m => m.default())\""
  },
  "devDependencies": {
    "@playwright/test": "1.61.0"
  }
}
